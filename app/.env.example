# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser by Next.js.
# Variables WITHOUT that prefix stay server-only and must never reach the client.

# --- Required ---

# Secret used by NextAuth to sign/encrypt the session JWT. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Google OAuth 2.0 client secret. SERVER-ONLY - do not add a NEXT_PUBLIC_ prefix.
GOOGLE_CLIENT_SECRET=

# Google OAuth 2.0 client id (public). Used by NextAuth and the Drive picker.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Picker API developer/API key (public). Used by the Drive file picker.
NEXT_PUBLIC_GOOGLE_PICKER_DEVELOPER_KEY=

# --- Optional ---

# Canonical URL of the deployment. Required by NextAuth in production when the
# app is not served from http://localhost:3000 (e.g. https://your-domain.example).
# NEXTAUTH_URL=https://your-domain.example
